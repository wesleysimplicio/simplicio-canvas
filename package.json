{
  "name": "simplicio-canvas",
  "private": true,
  "version": "2.6.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "build:demo": "VITE_CANVAS_DEMO=true VITE_BASE_PATH=/simplicio_canvas/ vite build --outDir dist-demo --emptyOutDir",
    "build:extension": "tsc --project extension/tsconfig.json --noEmit",
    "deploy:demo": "./scripts/deploy-demo.sh",
    "bootstrap": "node scripts/bootstrap.mjs --dry-run",
    "eval:transformation": "vitest run tests/m3-m4-contracts.test.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:privacy": "vitest run tests/privacy.test.ts",
    "test:a11y": "vitest run tests/a11y-contract.test.ts",
    "benchmark:render": "vitest run tests/render-benchmark.test.ts",
    "test:compatibility": "vitest run tests/compatibility-matrix.test.ts",
    "verify:compatibility": "node scripts/verify-compatibility.mjs",
    "scan:compatibility": "node scripts/scan-compatibility.mjs --offline",
    "scan:mapper": "node scripts/collect-compatibility-evidence.mjs",
    "scan:mapper:matrix": "node scripts/scan-matrix-mapper.mjs",
    "verify:artifact": "node scripts/verify-artifact.mjs --require-checksum",
    "benchmark:webgl": "vitest run tests/instancing-benchmark.test.ts",
    "test:onboarding": "vitest run tests/onboarding-usability.test.ts",
    "verify:pwa": "node scripts/verify-pwa.mjs",
    "verify:release": "node scripts/verify-release.mjs",
    "test:usability": "vitest run tests/onboarding-metrics.test.ts tests/onboarding-usability.test.ts",
    "test:readiness": "vitest run tests/release-readiness.test.ts",
    "test:evidence": "vitest run tests/compatibility-evidence.test.ts",
    "verify:readiness": "node scripts/verify-readiness.mjs"
  },
  "dependencies": { "three": "^0.178.0" },
  "devDependencies": {
    "@types/three": "^0.178.1",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.8.3",
    "vite": "^7.0.4",
    "vitest": "^3.2.4"
  }
}
