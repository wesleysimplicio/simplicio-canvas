{
  "name": "simplicio-canvas",
  "private": true,
  "version": "1.4.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "build:demo": "VITE_CANVAS_DEMO=true VITE_BASE_PATH=/simplicio_canvas/ vite build --outDir dist-demo --emptyOutDir",
    "build:extension": "tsc --project extension/tsconfig.json --noEmit",
    "deploy:demo": "./scripts/deploy-demo.sh",
    "bootstrap": "node scripts/bootstrap.mjs --dry-run",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": { "three": "^0.178.0" },
  "devDependencies": {
    "@types/three": "^0.178.1",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.8.3",
    "vite": "^7.0.4",
    "vitest": "^3.2.4"
  }
}
